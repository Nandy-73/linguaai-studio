# ── LinguaAI Studio — environment configuration ──────────────────────────────
# Copy to .env and adjust. Defaults work with docker-compose out of the box.

# App
APP_ENV=development
APP_NAME=LinguaAI Studio
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://backend:8000

# Security
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
INTERNAL_TOKEN=change-me-internal-worker-token

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://lingua:lingua@postgres:5432/lingua
DATABASE_URL_SYNC=postgresql+psycopg2://lingua:lingua@postgres:5432/lingua
POSTGRES_USER=lingua
POSTGRES_PASSWORD=lingua
POSTGRES_DB=lingua

# MongoDB (transcripts, segments, chat)
MONGO_URL=mongodb://mongo:27017
MONGO_DB=lingua

# Redis (broker, cache, pub/sub)
REDIS_URL=redis://redis:6379/0

# Object storage (MinIO locally; any S3-compatible in production, e.g. R2)
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=linguaai
S3_SECRET_KEY=linguaai-secret
S3_BUCKET=lingua
S3_REGION=us-east-1

# OAuth (leave empty to disable a provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# LLM provider (OpenAI-compatible endpoint, e.g. vLLM serving Qwen; empty = mock mode)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=qwen2.5-14b-instruct

# AI workers
AI_MOCK_MODE=auto            # auto | always | never  (auto = mock when models missing)
WHISPER_MODEL=large-v3
HF_TOKEN=                    # required for pyannote diarization models

# Frontend (baked at build; via nginx these defaults are fine)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=/api/v1/ws
